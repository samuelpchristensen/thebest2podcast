{{ printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom" xmlns:content="http://purl.org/rss/1.0/modules/content/" xmlns:itunes="http://www.itunes.com/dtds/podcast-1.0.dtd">
  <channel>
    <title>{{ .Site.Title }}</title>
    <link>{{ .Permalink }}</link>
    <description>{{ .Site.Params.description }}</description>
    <generator>Hugo -- gohugo.io</generator>
    <language>en-us</language>
    <lastBuildDate>{{ now.Format "Mon, 02 Jan 2006 15:04:05 -0700" }}</lastBuildDate>
    <atom:link href="{{ .Permalink }}" rel="self" type="application/rss+xml" />
    
    <!-- Podcast-specific tags -->
    <itunes:author>Samuel Christensen</itunes:author>
    <itunes:summary>{{ .Site.Params.description }}</itunes:summary>
    <itunes:owner>
      <itunes:name>Samuel Christensen</itunes:name>
      <itunes:email>samuelpchristensen@gmail.com</itunes:email>
    </itunes:owner>
    <itunes:image href="https://thebest2podcast.com/images/podcast-cover.jpg"/>
    <itunes:category text="Religion &amp; Spirituality">
      <itunes:category text="Christianity"/>
    </itunes:category>
    <itunes:explicit>clean</itunes:explicit>
    
    {{ range where .Site.RegularPages "Type" "episodes" }}
    <item>
      <title>{{ .Title }}</title>
      <link>{{ .Permalink }}</link>
      <pubDate>{{ .Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" }}</pubDate>
      <guid>{{ .Permalink }}</guid>
      <description>{{ .Summary }}</description>
      <content:encoded>{{ .Content | html }}</content:encoded>
      <itunes:episode>{{ .Params.episode }}</itunes:episode>
      <itunes:title>{{ .Title }}</itunes:title>
      <itunes:summary>{{ .Summary }}</itunes:summary>
      <itunes:duration>{{ .Params.duration }}</itunes:duration>
      <itunes:image href="https://img.youtube.com/vi/{{ .Params.youtube_id }}/maxresdefault.jpg"/>
    </item>
    {{ end }}
  </channel>
</rss>
